{
  "name": "singflow-ai",
  "private": true,
  "version": "0.1.0",
  "description": "SingFlow AI monorepo for an AI Native Karaoke & Music Workflow Studio.",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "build:web": "npm --workspace apps/web run build",
    "typecheck:web": "npm --workspace apps/web run typecheck",
    "dev:api": "python -m uvicorn app.main:app --reload --app-dir apps/api",
    "test:api": "pytest apps/api/tests",
    "test": "npm run typecheck:web && npm run test:api"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0",
    "python": ">=3.12"
  },
  "license": "MIT"
}
