# SingFlow AI root environment example
# Copy to .env for local development. Do not commit real secrets.

APP_ENV=local
LLM_PROVIDER=mock
OPENAI_API_KEY=replace-with-your-local-key-only

POSTGRES_USER=singflow
POSTGRES_PASSWORD=singflow_dev_password
POSTGRES_DB=singflow
DATABASE_URL=postgresql+psycopg://singflow:singflow_dev_password@localhost:5432/singflow

REDIS_URL=redis://localhost:6379/0

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
